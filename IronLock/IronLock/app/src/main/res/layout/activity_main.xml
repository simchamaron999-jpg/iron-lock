<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IRONLOCK"
            android:textColor="#FF2A2A"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No escape. No excuses."
            android:textColor="#666666"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="24dp" />

        <!-- Admin Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DEVICE ADMIN"
            android:textColor="#FF2A2A"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_admin_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔴 Device Admin: NOT ACTIVE"
            android:textColor="#F0F0F0"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_activate_admin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Activate Device Admin"
            android:backgroundTint="#FF2A2A"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Alarm Setup Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SET ALARM"
            android:textColor="#FF2A2A"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_alarm_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="06:30"
                android:textColor="#F0F0F0"
                android:textSize="36sp"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btn_pick_time"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Change"
                android:backgroundTint="#1C1C1C"
                android:textColor="#FF2A2A" />
        </LinearLayout>

        <!-- Duration -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RING DURATION (cannot dismiss)"
            android:textColor="#666666"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:layout_marginBottom="6dp" />

        <RadioGroup
            android:id="@+id/rg_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton android:id="@+id/rb_1min"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="1 min"
                android:textColor="#F0F0F0" android:buttonTint="#FF2A2A" />

            <RadioButton android:id="@+id/rb_3min"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="3 min"
                android:textColor="#F0F0F0" android:buttonTint="#FF2A2A" />

            <RadioButton android:id="@+id/rb_5min"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="5 min"
                android:textColor="#F0F0F0" android:buttonTint="#FF2A2A"
                android:checked="true" />

            <RadioButton android:id="@+id/rb_10min"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="10 min"
                android:textColor="#F0F0F0" android:buttonTint="#FF2A2A" />
        </RadioGroup>

        <!-- Toggles -->
        <Switch
            android:id="@+id/switch_block_power"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Block Power Off during alarm"
            android:textColor="#F0F0F0"
            android:textSize="13sp"
            android:checked="true"
            android:thumbTint="#FF2A2A"
            android:trackTint="#3A1010"
            android:padding="12dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="8dp" />

        <Switch
            android:id="@+id/switch_screen_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Force screen on during alarm"
            android:textColor="#F0F0F0"
            android:textSize="13sp"
            android:checked="true"
            android:thumbTint="#FF2A2A"
            android:trackTint="#3A1010"
            android:padding="12dp"
            android:background="@drawable/card_background"
            android:layout_marginBottom="16dp" />

        <!-- Next alarm status -->
        <TextView
            android:id="@+id/tv_next_alarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No alarm set"
            android:textColor="#666666"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <!-- Arm button -->
        <Button
            android:id="@+id/btn_arm_alarm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="ARM ALARM"
            android:backgroundTint="#FF2A2A"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1" />

    </LinearLayout>
</ScrollView>
