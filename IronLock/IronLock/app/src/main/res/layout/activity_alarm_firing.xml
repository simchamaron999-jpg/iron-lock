<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0A0000"
    android:padding="32dp">

    <!-- Alarm icon -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏰"
        android:textSize="72sp"
        android:layout_marginBottom="16dp" />

    <!-- Label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAKE UP"
        android:textColor="#FF2A2A"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.4"
        android:layout_marginBottom="4dp" />

    <!-- Big alarm time -->
    <TextView
        android:id="@+id/tv_alarm_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="06:30"
        android:textColor="#FFFFFF"
        android:textSize="80sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-condensed"
        android:letterSpacing="0.02"
        android:layout_marginBottom="32dp" />

    <!-- Countdown label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AUTO-DISMISS IN"
        android:textColor="#666666"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:layout_marginBottom="6dp" />

    <!-- Countdown timer -->
    <TextView
        android:id="@+id/tv_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="05:00"
        android:textColor="#FFAA00"
        android:textSize="48sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_marginBottom="40dp" />

    <!-- Status message -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔒 Device locked down. Cannot dismiss."
        android:textColor="#FF2A2A"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <!-- Blocked features list -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A0000"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● Power button blocked"
            android:textColor="#AA3333"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● Admin removal blocked"
            android:textColor="#AA3333"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="● App uninstall blocked"
            android:textColor="#AA3333"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</LinearLayout>
