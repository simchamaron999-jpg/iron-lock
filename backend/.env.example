# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mistymessenger

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Twilio (OTP)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=mistymessenger
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Firebase Admin (FCM)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Media limits
MAX_FILE_SIZE_BYTES=1073741824
IMAGE_COMPRESSION_QUALITY=85

# Extended revoke window (days)
REVOKE_WINDOW_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3001,https://app.mistymessenger.com
